www.leonwang.cc {
    # 直接提供上传的图片文件
    handle_path /uploads/* {
        root * /var/www/uploads
        file_server
        header Cache-Control "public, max-age=31536000, immutable"
    }

    # 其他请求代理到 Next.js
    reverse_proxy app:3000

    encode gzip

    request_body {
        max_size 20MB
    }
}
